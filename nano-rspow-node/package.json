{
  "name": "nano-rspow-node",
  "version": "0.4.0",
  "description": "Hybrid CPU/GPU Nano Proof of Work for Node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/CasualSecurityInc/nano-rspow"
  },
  "author": "Casual Security Inc. & Conny Brunnkvist <cbrunnkvist@gmail.com>",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "nano-rspow": "bin/cli.js"
  },
  "napi": {
    "name": "nano-rspow-node",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.3"
  }
}
