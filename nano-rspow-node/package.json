{
  "name": "nano-rspow-node",
  "version": "0.5.3",
  "description": "Hybrid CPU/GPU Nano Proof of Work for Node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/CasualSecurityInc/nano-rspow"
  },
  "author": "Casual Security Inc. & Conny Brunnkvist <cbrunnkvist@gmail.com>",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "nano-rspow": "bin/cli.js"
  },
  "files": [
    "index.d.ts",
    "index.js",
    "bin/"
  ],
  "napi": {
    "binaryName": "nano-rspow-node",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  }
}
